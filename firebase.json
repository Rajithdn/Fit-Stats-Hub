{
  "hosting": {
    "public": "artifacts/fitness-dashboard/dist/public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "predeploy": ["pnpm --filter @workspace/fitness-dashboard run build"],
    "rewrites": [
      { "source": "/api/**", "function": "api", "region": "us-central1" },
      { "source": "**", "destination": "/index.html" }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": ["node_modules", ".git", "*.log"],
      "predeploy": ["npm --prefix functions install && npm --prefix functions run build"]
    }
  ]
}
